<Window x:Class="ControleMaterialIBAA.View.Janelas.PopupHistoricoMaterial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histórico do Material"
        Height="450"
        Width="650"
        Background="#E8F0F0"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Histórico de Movimentações"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid x:Name="DgHistorico"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Data"
                                    Binding="{Binding dtmovimentacao}"
                                    Width="150"/>

                <DataGridTextColumn Header="Tipo"
                                    Binding="{Binding tipo}"
                                    Width="120"/>

                <DataGridTextColumn Header="Departamento"
                                    Binding="{Binding departamento}"
                                    Width="180"/>

                <DataGridTextColumn Header="Observação"
                                    Binding="{Binding observacao}"
                                    Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>