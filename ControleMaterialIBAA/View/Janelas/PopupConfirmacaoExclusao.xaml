<Window x:Class="ControleMaterialIBAA.View.Janelas.PopupConfirmacaoExclusao"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação"
        Height="180"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="15">

        <StackPanel VerticalAlignment="Center">

            <TextBlock x:Name="TxtMensagem"
                       Text="Tem certeza que deseja excluir esse material?"
                       FontSize="14"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Sim"
                        Width="100"
                        Margin="5"
                        Click="BtnSim_Click"/>

                <Button Content="Não"
                        Width="100"
                        Margin="5"
                        Click="BtnNao_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>