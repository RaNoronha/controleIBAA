<UserControl x:Class="ControleMaterialIBAA.View.Paginas.ConsultaSimplificadaMaterial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid Background="#6F9C9C">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= CABEÇALHO ================= -->
        <StackPanel Grid.Row="0"
                    Margin="0,30,0,20"
                    HorizontalAlignment="Center">

            <TextBlock Text="CONSULTA DE MATERIAIS"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Igreja Batista Altitude de Anchieta"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ================= CONTEÚDO ================= -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="1100"
                    Background="#6F9C9C">

            <!-- ================= FILTROS ================= -->
            <Border Padding="10"
                    Margin="0,0,0,10"
                    Background="#6F9C9C">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- MATERIAL -->
                    <TextBlock Text="Material:"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontWeight="Bold" Grid.ColumnSpan="2" Margin="60,0,160,0"/>

                    <TextBox x:Name="TxtMaterial"
                             Grid.Column="1"
                             Margin="5"/>

                    <!-- DEPARTAMENTO -->
                    <TextBlock Text="Departamento:"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontWeight="Bold" Grid.ColumnSpan="2" Margin="31,0,189,0"/>

                    <ComboBox x:Name="CmbDepartamentos"
                              Grid.Column="3"
                              Margin="5"
                              DisplayMemberPath="nome"
                              SelectedValuePath="id"/>

                    <!-- TIPO -->
                    <TextBlock Text="Tipo de Material:"
                               Grid.Column="4"
                               VerticalAlignment="Center"
                               FontWeight="Bold" Grid.ColumnSpan="2" Margin="21,0,199,0"/>

                    <ComboBox x:Name="CmbTipoMaterial"
                              Grid.Column="5"
                              Margin="5"/>

                </Grid>

            </Border>

            <!-- ================= BOTÃO ================= -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,10">

                <Button Content="Pesquisar"
                        Width="100"
                        Height="30"
                        FontWeight="Bold"
                        Background="#3E6F6F"
                        Foreground="White"
                        BorderThickness="0"
                        Click="BtnPesquisar_Click"/>
            </StackPanel>

            <!-- ================= GRID RESUMIDA ================= -->
            <DataGrid x:Name="DgMateriais"
                      AutoGenerateColumns="False"
                      Height="600"
                      CanUserAddRows="False"
                      Margin="0,10,0,0"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Material"
                                        Binding="{Binding material}"
                                        Width="300"/>

                    <DataGridTextColumn Header="Departamento"
                                        Binding="{Binding departamento}"
                                        Width="250"/>

                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding tipoMaterial}"
                                        Width="200"/>

                    <DataGridTextColumn Header="Quantidade"
                                        Binding="{Binding quantidade}"
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

    </Grid>
</UserControl>