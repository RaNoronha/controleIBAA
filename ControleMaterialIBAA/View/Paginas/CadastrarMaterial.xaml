<UserControl x:Class="ControleMaterialIBAA.View.Paginas.CadastrarMaterial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"            
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>

        <!-- ESTILO CAMPOS -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>            
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#B0C4C4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B0C4C4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ESTILO BOTÃO -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#3E6F6F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10"/>
        </Style>        

    </UserControl.Resources>

    <!-- FUNDO -->
    <Grid Background="#6F9C9C">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= CABEÇALHO ================= -->
        <StackPanel Grid.Row="0"
                    Margin="0,30,0,20"
                    HorizontalAlignment="Center">

            <TextBlock Text="CADASTRO DE MATERIAL"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Igreja Batista Anchieta"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ================= CONTEÚDO ================= -->
        <Border Grid.Row="1"
                Background="#6F9C9C"
                Padding="20">

            <StackPanel HorizontalAlignment="Center"
                        Width="1100">

                <!-- FORMULÁRIO -->
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <!-- LINHA 0 -->
                    <TextBlock Text="Material:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtMaterial" Grid.Row="0" Grid.Column="1"/>

                    <TextBlock Text="Descrição:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtDescricao" Grid.Row="0" Grid.Column="4"/>

                    <!-- LINHA 1 -->
                    <TextBlock Text="Marca/Modelo:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtMarcaModelo" Grid.Row="1" Grid.Column="1"/>

                    <TextBlock Text="QTD:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtQtd" Grid.Row="1" Grid.Column="4"/>

                    <!-- LINHA 2 -->
                    <TextBlock Text="Departamento:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <ComboBox x:Name="CmbDepartamentos" SelectionChanged="CmbDepartamentos_SelectionChanged" Grid.Row="2" Grid.Column="1"/>

                    <TextBlock Text="Sub-Departamento:" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <ComboBox x:Name="CmbSubDepartamentos" Grid.Row="2" Grid.Column="4" DisplayMemberPath="nome" SelectedValuePath="id"/>

                    <TextBlock Text="Tipo Material:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <ComboBox x:Name="CmbTipoMaterial" Grid.Row="3" Grid.Column="1"/>


                    <!-- LINHA 3 -->

                    <!-- SEPARADOR -->
                    <Separator Grid.Row="4" Grid.ColumnSpan="5" Margin="0,10"/>

                    <!-- LINHA 5 -->
                    <TextBlock Text="Valor Unitário(R$):" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtValor" Grid.Row="5" Grid.Column="1"/>

                    <TextBlock Text="Valor Total(R$):" Grid.Row="5" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" />
                    <TextBox x:Name="TxtValorTotal" Grid.Row="5" Grid.Column="4" IsReadOnly="True" Background="#EAEAEA" Margin="0,5,150,5"/>

                    <TextBlock Text="Forma de Aquisição:" Grid.Row="3" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <ComboBox x:Name="CmbAquisicao"  Grid.Row="3"  Grid.Column="4"/>

                    <!-- LINHA 6 -->
                    <TextBlock Text="Responsável:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <TextBox x:Name="TxtResponsavel" Grid.Row="6" Grid.Column="1"/>

                    <TextBlock Text="Data de Verificação:" Grid.Row="6" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <DatePicker x:Name="DtVerificacao" Grid.Row="6" Grid.Column="4" Margin="0,5,0,5"/>

                </Grid>

                <!-- BOTÕES -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">

                    <Button Content="Salvar"
                            Click="BtnSalvar_Click"/>
                    
                    <Button Content="Cancelar"
                            Background="#A94442"/>
                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>