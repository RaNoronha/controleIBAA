<UserControl x:Class="ControleMaterialIBAA.View.Paginas.GerenciarMaterial"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid Background="#6F9C9C">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabeçalho -->
            <RowDefinition Height="*"/>
            <!-- Seu conteúdo -->
        </Grid.RowDefinitions>

        <!-- ================= CABEÇALHO ================= -->
        <StackPanel Grid.Row="0"
                    Margin="0,30,0,20"
                    HorizontalAlignment="Center">

            <TextBlock Text="GERENCIAR MATERIAL"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Igreja Batista Altitude de Anchieta"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>


        <!-- ================= SEU CÓDIGO ORIGINAL ================= -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Width="1100"
                    Background="#6F9C9C">

            <!-- ================= FILTROS EM UMA LINHA ================= -->

            <!-- ================= FILTROS EM UMA LINHA ================= -->
            <Grid Background="#6F9C9C">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="99"/>
                    <ColumnDefinition Width="191"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Código:"
                           VerticalAlignment="Center"
                           FontWeight="Bold" Margin="117,0,134,0" Grid.Column="2" Grid.ColumnSpan="2"/>

                <TextBox x:Name="TxtCod"
                         Margin="177,5,105,5" Grid.Column="2" Grid.ColumnSpan="2"/>

                <!-- Tipo Material -->
                <TextBlock Text="Tipo Material:"
                           Grid.Column="3"
                           FontWeight="Bold"
                           Margin="102,8,98,8" Grid.ColumnSpan="2"/>

                <ComboBox x:Name="CmbTipoMaterial"
                          Grid.Column="4"
                          Margin="15,5,125,5"
                          Grid.ColumnSpan="2"
                          SelectedValuePath="Key"
                          DisplayMemberPath="Value"/>

            </Grid>

            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,10,0,10">

                <Button Content="Pesquisar"
            Width="100"
            Height="30"
            FontWeight="Bold"
            Background="#3E6F6F"
            Foreground="White"
            BorderThickness="0"
            Margin="1" 
            Click="BtnPesquisar_Click"/>

            <Button Content="Excluir"
            Width="100"
            Height="30"
            FontWeight="Bold"
            Background="#A94442"
            Foreground="White"
            BorderThickness="0"
            Margin="10"
            Click="BtnExcluir_Click"/>

            </StackPanel>

            <!-- ================= LISTAGEM ================= -->
            <DataGrid x:Name="DgMateriais"
                      AutoGenerateColumns="False"
                      Height="600"
                      CanUserAddRows="False"
                      SelectionMode="Extended"
                      Margin="0,10,0,0">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Selecionar" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding selecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding cod}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Material"
                                        Binding="{Binding nome}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Descrição"
                                        Binding="{Binding descricao}"
                                        Width="180"/>

                    <DataGridTextColumn Header="Marca"
                                        Binding="{Binding marca}"
                                        Width="180"/>

                    <DataGridTemplateColumn Header="Histórico" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <Button Content="Ver"
                             Width="60"
                             Height="25"
                             Background="#3E6F6F"
                             Foreground="White"
                             Tag="{Binding id}"
                             Click="BtnHistoricoMaterial_Click"/>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>

    </Grid>
</UserControl>